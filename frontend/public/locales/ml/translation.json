  "about": {
    "pageTitle": "LuxuryStay-നെക്കുറിച്ച്",
    "heroTitle": "ആഡംബര ഹോസ്പിറ്റാലിറ്റി പുനർനിർവചിക്കുന്നു",
    "heroSubtitle": "2010 മുതൽ, വിവേകശീലരായ സഞ്ചാരികൾക്കായി അസാധാരണ അനുഭവങ്ങൾ ഞങ്ങൾ ക്യുറേറ്റ് ചെയ്യുന്നു.",
    "ourStory": "ഞങ്ങളുടെ കഥ",
    "storyContent": "LuxuryStay ഒരു ഏകീകൃത ദൃഷ്ടിയോടെ സ്ഥാപിച്ചതാണ്: ആഡംബര ഹോസ്പിറ്റാലിറ്റിയുടെ അർത്ഥം പുനർനിർവചിക്കുക. അസാധാരണ പ്രോപ്പർട്ടികളുടെ ഒരു ബോട്ടീക് ശേഖണമായി ആരംഭിച്ചത്, ലോകത്തിലെ ഏറ്റവും അസാധാരണ താമസങ്ങളുമായി സഞ്ചാരികളെ ബന്ധിപ്പിക്കുന്ന ഒരു ആഗോള പ്ലാറ്റ്ഫോമായി വികസിച്ചു.",
    "ourMission": "ഞങ്ങളുടെ ദൗത്യം",
    "missionContent": "ഓരോ യാത്രയും അസാധാരണമായിരിക്കണമെന്ന് ഞങ്ങൾ വിശ്വസിക്കുന്നു. അപരാധിനുള്ള സേവനം, അത്ഭുതകരമായ സ്ഥലങ്ങൾ, മറക്കാനാവാത്ത അനുഭവങ്ങൾ എന്നിവ നൽകുന്ന കൈതിരഞ്ഞെടുത്ത ആഡംബര പ്രോപ്പർട്ടികളുമായി വിവേകശീലരായ സഞ്ചാരികളെ ബന്ധിപ്പിക്കുക എന്നതാണ് ഞങ്ങളുടെ ദൗത്യം.",
    "ourValues": "ഞങ്ങളുടെ മൂല്യങ്ങൾ",
    "value1Title": "മികവ്",
    "value1Content": "ഗുണമേന്മയിൽ ഞങ്ങൾ ഒരിക്കലും വിട്ടുവീഴ്ച ചെയ്യുന്നില്ല. ഞങ്ങളുടെ ശേഖണത്തിലെ ഓരോ പ്രോപ്പർട്ടിയും ആഡംബരത്തിന്റെയും സേവനത്തിന്റെയും ഏറ്റവും ഉയർന്ന മാനദണ്ഡങ്ങൾ പാലിക്കുന്നു.",
    "value2Title": "യഥാർത്ഥത്വം",
